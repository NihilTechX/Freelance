# ─────────────────────────────────────────────────────────────
# EliteMatch — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────

# Application
APP_NAME=EliteMatch
APP_VERSION=1.0.0
DEBUG=true

# Database (PostgreSQL)
# Local:      postgresql+asyncpg://user:password@localhost:5432/freelance_db
# Render.com: provided automatically via render.yaml
DATABASE_URL=postgresql+asyncpg://freelance_user:freelance_pass@localhost:5432/freelance_db

# Redis
# Local:   redis://localhost:6379/0
# Upstash: rediss://default:<token>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# JWT — change JWT_SECRET_KEY to a long random string in production
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery (uses Redis as broker)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS — add your frontend URL(s) as a JSON array
# Local:      ["http://localhost:5173","http://localhost:5174"]
# Production: ["https://your-app.vercel.app"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:5175","http://localhost:5176"]
